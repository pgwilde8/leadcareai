# App
APP_NAME=LeadCare AI
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=https://leadcareai.com
PUBLIC_BASE_URL=https://leadcareai.com
SECRET_KEY=change-me

# Social (footer icons — leave blank to hide)
LINKEDIN_URL=
FACEBOOK_URL=
YOUTUBE_URL=

# Database
DATABASE_URL=postgresql+psycopg://webadmin:CHANGE_ME@localhost:5432/leadcareai

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth/Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Partner W-9 (Fernet key — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PARTNER_TAX_ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_GROWTH_MONTHLY=
# Alias for recurring $147/mo Price ID (price_...) if you prefer one product name in .env:
STRIPE_PRICE_ID_GROWTH_PRODUCT=
STRIPE_PRICE_ID_SETUP_FEE=
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:8788/business/billing

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_AUTH_ENABLED=false

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true
OPENAI_TIMEOUT_SECONDS=20

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@leadcareai.com

# Notifications
DEFAULT_SUPPORT_EMAIL=support@leadcareai.com
